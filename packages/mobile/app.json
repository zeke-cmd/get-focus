{
  "expo": {
    "icon": "./assets/icon.png",
    "android": {
      "package": "com.getfocus_z7k2.runable",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.getfocus_z7k2.runable",
      "supportsTablet": true
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "name": "focus",
    "slug": "get-focus",
    "version": "0.0.1",
    "scheme": "getfocus",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-sqlite",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#000000"
        }
      ],
      "expo-calendar",
      "expo-local-authentication",
      "expo-document-picker"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b3506972-85c8-45bc-a42c-4bf8817f6340"
      }
    },
    "owner": "zeke-cmd"
  }
}
