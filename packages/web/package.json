    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.10",
    "lucide-react": "^0.577.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.71.2",
    "react-icons": "^5.6.0",
    "tailwind-merge": "^3.5.0",
