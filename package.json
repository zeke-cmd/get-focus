{
  "name": "get-focus",
  "private": true,
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "cd packages/mobile && bunx expo start",
    "android": "cd packages/mobile && bunx expo start --android",
    "ios": "cd packages/mobile && bunx expo start --ios",
    "typecheck": "cd packages/mobile && bunx tsc --noEmit",
    "test": "cd packages/mobile && bunx jest"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
